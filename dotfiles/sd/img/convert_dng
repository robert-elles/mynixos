#!/usr/bin/env bash

# Script to convert all .dng files in a folder to high-quality JPEG files in place
# Usage: ./convert_dng <folder_path>

set -uo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to show usage
show_usage() {
    echo "Usage: $0 <folder_path>"
    echo ""
    echo "This script converts all .dng files in the specified folder to high-quality JPEG files in place."
    echo ""
    echo "Arguments:"
    echo "  folder_path    Path to the folder containing .dng files"
    echo ""
    echo "Examples:"
    echo "  $0 /path/to/photos"
    echo "  $0 ."
    echo ""
    echo "Requirements:"
echo "  - ImageMagick (magick command)"
}

# Function to check dependencies
check_dependencies() {
    if ! command -v convert &> /dev/null; then
        print_error "ImageMagick is not installed. Please install it first:"
        echo "  - Ubuntu/Debian: sudo apt install imagemagick"
        echo "  - CentOS/RHEL: sudo yum install ImageMagick"
        echo "  - Arch: sudo pacman -S imagemagick"
        echo "  - NixOS: Add imagemagick to environment.systemPackages"
        exit 1
    fi
}

# Function to convert a single DNG file
convert_dng_to_jpeg() {
    local dng_file="$1"
    local jpeg_file="${dng_file%.dng}.jpg"
    
    print_status "Converting: $(basename "$dng_file")"
    
    # Convert DNG to JPEG with high quality settings
    if magick "$dng_file" \
        -quality 95 \
        -strip \
        -interlace Plane \
        -sampling-factor 4:2:0 \
        "$jpeg_file" 2>&1; then
        
        # Get file sizes for comparison
        local dng_size=$(stat -c%s "$dng_file" 2>/dev/null || stat -f%z "$dng_file" 2>/dev/null)
        local jpeg_size=$(stat -c%s "$jpeg_file" 2>/dev/null || stat -f%z "$jpeg_file" 2>/dev/null)
        
        if [ -n "$dng_size" ] && [ -n "$jpeg_size" ]; then
            local size_reduction=$(( (dng_size - jpeg_size) * 100 / dng_size ))
            print_success "Converted: $(basename "$dng_file") → $(basename "$jpeg_file") (${size_reduction}% size reduction)"
        else
            print_success "Converted: $(basename "$dng_file") → $(basename "$jpeg_file")"
        fi
        
        return 0
    else
        print_error "Failed to convert: $(basename "$dng_file")"
        return 1
    fi
}

# Main function
main() {
    # Check if folder path is provided
    if [ $# -eq 0 ]; then
        print_error "No folder path provided"
        show_usage
        exit 1
    fi
    
    # Check if help is requested
    if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
        show_usage
        exit 0
    fi
    
    local folder_path="$1"
    
    # Check if folder exists
    if [ ! -d "$folder_path" ]; then
        print_error "Folder does not exist: $folder_path"
        exit 1
    fi
    
    # Check dependencies
    check_dependencies
    
    # Change to the specified directory
    cd "$folder_path"
    print_status "Working in: $(pwd)"
    
    # Find all .dng files
    local dng_files=($(find . -maxdepth 1 -name "*.dng" -type f))
    
    if [ ${#dng_files[@]} -eq 0 ]; then
        print_warning "No .dng files found in: $folder_path"
        exit 0
    fi
    
    print_status "Found ${#dng_files[@]} .dng file(s) to convert"
    echo ""
    
    # Convert each DNG file
    local success_count=0
    local fail_count=0
    
    for dng_file in "${dng_files[@]}"; do
        print_status "Processing file $((success_count + fail_count + 1)) of ${#dng_files[@]}: $(basename "$dng_file")"
        if convert_dng_to_jpeg "$dng_file"; then
            ((success_count++))
        else
            ((fail_count++))
            print_warning "Continuing with next file..."
        fi
        echo ""
    done
    
    # Summary
    echo "========================================"
    print_status "Conversion Summary:"
    echo "  Total files: ${#dng_files[@]}"
    print_success "  Successful: $success_count"
    if [ $fail_count -gt 0 ]; then
        print_error "  Failed: $fail_count"
    fi
    echo "========================================"
    
    if [ $fail_count -gt 0 ]; then
        exit 1
    fi
}

# Run main function with all arguments
main "$@"

