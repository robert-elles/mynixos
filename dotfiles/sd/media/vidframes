#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: getvideoframes <video-url> [output-dir]"
  exit 1
fi

input="$1"

if [[ -f "$input" ]]; then
  videofile="$input"
  basename=$(basename "${videofile%.*}")
  output_dir="${2:-$basename}"
else
  tmpfile=$(mktemp /tmp/getvideoframes.XXXXXX.mp4)
  trap 'rm -f "$tmpfile"' EXIT

  echo "Downloading video..."
  yt-dlp -o "$tmpfile" --force-overwrites "$input"

  videofile="$tmpfile"
  filename=$(yt-dlp --print filename -o "%(title)s" "$input")
  output_dir="${2:-$filename}"
fi

mkdir -p "$output_dir"

echo "Extracting unique frames to $output_dir..."
ffmpeg -i "$videofile" -vf "select='gt(scene,0.3)'" -vsync vfr -q:v 1 "$output_dir/frame_%04d.jpg"

count=$(ls -1 "$output_dir"/frame_*.jpg 2>/dev/null | wc -l)
echo "Done. Extracted $count frames."

