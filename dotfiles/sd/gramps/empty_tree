#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GRAMPS_BIN="/Applications/Gramps.app/Contents/MacOS/Gramps"
PLUGIN_SRC="$SCRIPT_DIR/EmptyFamilyTree"
PLUGIN_DEST="$HOME/Library/Application Support/gramps/gramps60/plugins/EmptyFamilyTree"
FAMILY_TREE="Gramps Web"
TREE_DIR="$HOME/Library/Application Support/gramps/grampsdb/322b11e0-b651-49b6-b4a4-a53577da0904"
BACKUP_DIR="$HOME/Downloads/personal/stammbaum/gramps_backup_$(date +%Y%m%d_%H%M%S)"

if pgrep -x Gramps > /dev/null; then
  echo "Gramps.app is running and may hold a lock on \"$FAMILY_TREE\". Quit it first." >&2
  exit 1
fi

read -r -p "This will delete ALL data in \"$FAMILY_TREE\" (keeping its database id). Continue? [y/N] " reply
case "$reply" in
  [yY]|[yY][eE][sS]) ;;
  *) echo "Aborted."; exit 1 ;;
esac

echo "Backing up sqlite.db/undo.db to $BACKUP_DIR"
mkdir -p "$BACKUP_DIR"
cp "$TREE_DIR/sqlite.db" "$BACKUP_DIR/sqlite.db"
cp "$TREE_DIR/undo.db" "$BACKUP_DIR/undo.db"

echo "Syncing plugin to $PLUGIN_DEST"
mkdir -p "$PLUGIN_DEST"
rsync -a --delete --exclude '__pycache__' "$PLUGIN_SRC/" "$PLUGIN_DEST/"

echo "Emptying \"$FAMILY_TREE\""
"$GRAMPS_BIN" -O "$FAMILY_TREE" -a tool -p name=empty_family_tree -y
