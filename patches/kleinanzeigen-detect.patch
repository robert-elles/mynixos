+    public function detectParameters($url)
+    {
+        $parsed = parse_url($url);
+        $host = $parsed['host'] ?? '';
+        if (!str_ends_with($host, 'kleinanzeigen.de')) {
+            return null;
+        }
+
+        $path = $parsed['path'] ?? '';
+
+        // Profile URL: /s-bestandsliste.html?userId=12345678
+        if (str_contains($path, 's-bestandsliste.html')) {
+            parse_str($parsed['query'] ?? '', $queryParams);
+            if (isset($queryParams['userId'])) {
+                return [
+                    'context' => 'By profile',
+                    'userid' => (int) $queryParams['userId'],
+                    'pages' => 1,
+                ];
+            }
+        }
+
+        if (str_contains($path, 's-suchanfrage.html')) {
+            parse_str($parsed['query'] ?? '', $queryParams);
+            return [
+                'context' => 'By search',
+                'query' => $queryParams['keywords'] ?? '',
+                'pages' => 1,
+            ];
+        }
+
+        if (preg_match('#/s-([^/]+)/k0#', $path, $matches)) {
+            return [
+                'context' => 'By search',
+                'query' => str_replace('-', ' ', $matches[1]),
+                'pages' => 1,
+            ];
+        }
+
+        return null;
+    }
