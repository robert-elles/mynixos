+  "version": "0.32.0",
+  "hash": "sha256-JuH6+uhx+jWX7SS0+itgyvfPf+RBOpXOOLCKACHdvvg=",
+  "npmHash": "sha256-+GfnyecDI+boIeZOyiluWnbUfF+NgeXg9ywfH7ZmccA="
